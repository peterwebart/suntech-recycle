# Public site URL — used for canonical, hreflang, sitemap, OG (set in Coolify build env)
NEXT_PUBLIC_SITE_URL=https://suntechrecycle.com

# Collection form email (SMTP). Until these are set, the form still works and
# returns a reference number, but no email is sent. Use the mailbox SMTP for
# nick@suntechrecycle.com (or any provider).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true for port 465
SMTP_USER=
SMTP_PASS=
MAIL_TO=nick@suntechrecycle.com
MAIL_FROM=SunTech Recycle <no-reply@suntechrecycle.com>
